<Window x:Class="AuroraSuite.FtpBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Browse Console Folder" Height="480" Width="520" MinHeight="360" MinWidth="420"
        Background="{DynamicResource Brush.WindowBg}"
        Foreground="{DynamicResource Brush.Text}"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="CanResizeWithGrip" AllowsTransparency="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34" ResizeBorderThickness="5" CornerRadius="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource Brush.PanelBgAlt}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="BROWSE CONSOLE FOLDER" Margin="12,0,0,0" FontSize="12"
                       FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                    Style="{StaticResource ChromeButton}" Click="CancelButton_Click"/>
        </Grid>

        <Grid Grid.Row="1" Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource GridFrame}" Margin="0,0,0,6">
                <TextBlock x:Name="PathText" Text="/" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
            </Border>
            <TextBlock Grid.Row="1" x:Name="StatusText" Style="{StaticResource MutedText}" Margin="0,0,0,8"/>

            <Border Grid.Row="2" Style="{StaticResource GridFrame}">
                <ListView x:Name="FolderListView" Background="Transparent" BorderThickness="0"
                          MouseDoubleClick="FolderListView_MouseDoubleClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="13" Margin="4,3"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Up" Style="{StaticResource BtnSecondary}" Click="UpButton_Click" Margin="0,0,8,0"/>
                <Button Content="Select This Folder" Style="{StaticResource BtnPrimary}" Click="SelectButton_Click" Margin="0,0,8,0"/>
                <Button Content="Cancel" Style="{StaticResource BtnSecondary}" Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
